# --- STAGE 1: The Builder (Debian Slim is stable on Render) ---
FROM haskell:9.6.5-slim AS builder

# Debian uses apt-get, not apk. build-essential replaces g++, gcc, and make.
RUN apt-get update && apt-get install -y \
    build-essential \
    libffi-dev \
    libgmp-dev \
    libncurses-dev \
    libz-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY *.cabal ./
RUN cabal update && cabal build --only-dependencies --disable-optimization

COPY . .

# -j1 is crucial to avoid OOM kills during compilation
RUN cabal build --disable-optimization -j1 && \
    mkdir -p /install && \
    cp $(find dist-newstyle -name imd-server -type f) /install/imd-server

# --- STAGE 2: The Final Image ---
# We use debian-slim here because a binary built on Debian won't run on Alpine 
# due to different C libraries (glibc vs musl).
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    libffi8 \
    libgmp10 \
    libncurses6 \
    libz1 \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /install/imd-server .
RUN chmod +x ./imd-server

EXPOSE 8080

CMD ["./imd-server"]