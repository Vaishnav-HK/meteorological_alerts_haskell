# --- STAGE 1: The Builder ---
# Change from 9.4.6-slim to 9.6.4-slim (which uses a newer Debian)
FROM haskell:9.6.4-slim AS builder

# Install C libraries needed for the build
RUN apt-get update && apt-get install -y \
    libz-dev \
    pkg-config \
    libncurses-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# The rest of your file remains the same...
COPY *.cabal ./
RUN cabal update && cabal build --only-dependencies --disable-optimization

COPY . .

RUN cabal build --disable-optimization && \
    mkdir -p /install && \
    cp $(find dist-newstyle -name imd-server -type f) /install/imd-server

# --- STAGE 2: The Final Image ---
FROM debian:bookworm-slim

# Install ONLY the runtime libraries (much smaller than -dev versions)
RUN apt-get update && apt-get install -y \
    libz1 \
    libncurses6 \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy ONLY the finished binary from the builder stage
COPY --from=builder /install/imd-simulator.cabal .

# Ensure the binary is executable
RUN chmod +x ./imd-simulator.cabal

# Start the server
CMD ["./imd-simulator.cabal"]