# --- STAGE 1: The Builder ---
# Using the image that successfully extracted in your logs
FROM haskell:9.6.5 AS builder

# Install C libraries needed for the build (Debian uses apt-get)
RUN apt-get update && apt-get install -y \
    libz-dev \
    pkg-config \
    libncurses-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# The rest of your file remains the same...
COPY *.cabal ./
RUN cabal update && cabal build --only-dependencies --disable-optimization

COPY . .

# Build with -j1 to keep memory usage low during the actual compile
RUN cabal build --disable-optimization -j1 && \
    mkdir -p /install && \
    cp $(find dist-newstyle -name imd-server -type f) /install/imd-server

# --- STAGE 2: The Final Image ---
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    libz1 \
    libncurses6 \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /install/imd-server .

RUN chmod +x ./imd-server

CMD ["./imd-server"]