# --- STAGE 1: The Builder ---
# Using the floating 9.6 tag to ensure the image is found by the registry.
FROM haskell:9.6 AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    libffi-dev \
    libgmp-dev \
    libncurses-dev \
    libz-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Optimization: Copy only cabal file first to cache dependency builds
COPY *.cabal ./
RUN cabal update && cabal build --only-dependencies --disable-optimization

COPY . .

# -j1 is smart for Render/low-RAM environments to prevent OOM
RUN cabal build --disable-optimization -j1 --ghc-options="-threaded -with-rtsopts=-N" && \
    mkdir -p /install && \
    cp $(find dist-newstyle -name imd-server -type f) /install/imd-server

# --- STAGE 2: The Final Image ---
FROM debian:bookworm-slim

# Note: Bookworm uses newer library versions (libffi8, libncurses6, etc.)
RUN apt-get update && apt-get install -y \
    libffi8 \
    libgmp10 \
    libncurses6 \
    libz1 \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /install/imd-server .
RUN chmod +x ./imd-server

EXPOSE 8080

# It's good practice to ensure the binary handles signals correctly
CMD ["./imd-server"]